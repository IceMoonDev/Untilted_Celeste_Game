,"FlashColor","0","\"255;0;0\"",""]},{"type":{"value":"ResetObjectTimer"},"parameters":["PlayerHitbox","\"StopFirstTintFlash\""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the timer we started above is greater or equal to 4 seconds\nthen we stop flashhing the skin and delete the timer"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CompareObjectTimer"},"parameters":["PlayerHitbox","\"StopFirstTintFlash\"",">=","4"]}],"actions":[{"type":{"value":"Flash::FlashColor::Stop"},"parameters":["PlayerSkin","FlashColor",""]},{"type":{"value":"RemoveObjectTimer"},"parameters":["PlayerHitbox","\"StopFirstTintFlash\""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if climb key (Z by default) is pressed"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Climb"]}],"actions":[],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"and exhausted variable is greater or equal to 6\nthen we set the player exhausted variable to true\nand we set the player climbing variable to false (means the player is no longer climbing)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["ExhaustedMeter",">=","6"]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","Exhausted","True",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","False",""]}],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"then we reset the player falling speed back to default (400)\nand we set the Activate exhausted variable to true (means the player is now exhausted)\nand we set the flash peroid to 0.1 seconds (game feel)\nand we flash the skin for Red color"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"PlatformBehavior::MaxFallingSpeed"},"parameters":["PlayerHitbox","PlatformerObject","=","400",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","ActivateExhaustedState","True",""]},{"type":{"value":"Flash::FlashColor::SetHalfPeriodTime"},"parameters":["PlayerSkin","FlashColor","=","0.1",""]},{"type":{"value":"Flash::FlashColor::Flash"},"parameters":["PlayerSkin","FlashColor","0","\"255;0;0\"",""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the player exhausted variable is true (set from the event above)\nand player is not jumping"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","ActivateExhaustedState","True",""]},{"type":{"inverted":true,"value":"PlatformBehavior::IsJumping"},"parameters":["PlayerHitbox","PlatformerObject"]}],"actions":[],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if skin was not flipped horizontally (looking right)\nthen we simulate moving right for player (this will make the player keep sliding on the wall when exhausted)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"inverted":true,"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"PlatformBehavior::SimulateControl"},"parameters":["PlayerHitbox","PlatformerObject","\"Right\""]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"PlatformBehavior::SimulateControl"},"parameters":["PlayerHitbox","PlatformerObject","\"Left\""]}]}]}]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if player exhausted state variable was true\nand player has jumped from a wall\nwe set it to false (to not allow the events above to run, we dont want to simulate movements for the player if the player has wall jumped)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","ActivateExhaustedState","True",""]},{"type":{"value":"AdvancedJump::WallJump::HasJustWallJumped"},"parameters":["PlayerHitbox","WallJump",""]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","ActivateExhaustedState","False",""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the skin was flashing\nand the player was on floor\nthen we set the player exhausted variable to false (to reset the exhausted variable)\nthen we delete the flash timer\nand we stop flashing the skin"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"Flash::FlashColor::IsFlashing"},"parameters":["PlayerSkin","FlashColor",""]},{"type":{"value":"PlatformBehavior::IsOnFloor"},"parameters":["PlayerHitbox","PlatformerObject"]},{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","Exhausted","False",""]},{"type":{"value":"RemoveObjectTimer"},"parameters":["PlayerHitbox","\"StopFirstTintFlash\""]},{"type":{"value":"Flash::FlashColor::Stop"},"parameters":["PlayerSkin","FlashColor",""]}],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if skin animation was SlidingOnWall\nthen we set the cantPressClimb variable to true (used to not allow the player to be able to climbg/hold on wall while exhausted)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"AnimatableCapability::AnimatableBehavior::Name"},"parameters":["PlayerSkin","Animation","=","\"SlidingOnWall\""]}],"actions":[{"type":{"value":"SetBooleanVariable"},"parameters":["CantPressClimbKey","True",""]}]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Enable","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if climb key is pressed (Z by default)\nand player was not jumping from wall to another (variable is false)\nand player was not climbing (variable is false)\nand player was not dashing (variable is false)\nand player was not exhausted (variable is false)\nand player was not dead (variable is false)\nand player cant press climb key (variable is false)\nand the level has started (variable is true)\nand the level didnt finish yet (variable is false)\nand the game is not paused (variable is false)\nand if the skin was not flipped horizontally (looking to right) and the raycast is in collision with the wall on the right side (we store the collision X position in a variable to use it in the snap events below)\nor\nand if the skin was flipped horizontally (looking to left) and the raycast is in collision with the wall on the left side (we store the collision X position in a variable to use it in the snap events below)\nthen we set the player climb variable to true (means the player is now climbing)\nand we abort the player current jump (in case he was jumping)\nand we set the cant climb variable to true\nthen we start the timer (used to change the player falling speed in the events below, we didnt put the falling speed actions in this event directly because it takes like 0.01 seconds for the player to stop other falling speed and register the new one, thats why we use a timer and give it 0.05 seconds in the event below this one)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Climb"]},{"type":{"value":"BooleanVariable"},"parameters":["IsJumpingFromWallToAnother","False",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","False",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDashing","False",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","Exhausted","False",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","=",""]},{"type":{"value":"BooleanVariable"},"parameters":["CantPressClimbKey","=",""]},{"type":{"value":"BooleanVariable"},"parameters":["LevelStarted","True",""]},{"type":{"value":"BooleanVariable"},"parameters":["LevelIsFinished","=",""]},{"type":{"value":"BooleanVariable"},"parameters":["PauseGame","=",""]},{"type":{"value":"BuiltinCommonInstructions::Or"},"parameters":[],"subInstructions":[{"type":{"value":"BuiltinCommonInstructions::And"},"parameters":[],"subInstructions":[{"type":{"inverted":true,"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]},{"type":{"value":"Raycast"},"parameters":["AllLevelsCollisions","PlayerHitbox.X()+27","PlayerHitbox.Y()+12","90","16","PlayerRightWallCollisionXPosition","",""]}]},{"type":{"value":"BuiltinCommonInstructions::And"},"parameters":[],"subInstructions":[{"type":{"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]},{"type":{"value":"Raycast"},"parameters":["AllLevelsCollisions","PlayerHitbox.X()+5","PlayerHitbox.Y()+12","90","16","PlayerLeftWallCollisionXPosition","",""]}]}]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","True",""]},{"type":{"value":"PlatformBehavior::PlatformerObjectBehavior::AbortJump"},"parameters":["PlayerHitbox","PlatformerObject"]},{"type":{"value":"SetBooleanVariable"},"parameters":["CantPressClimbKey","True",""]},{"type":{"value":"ResetTimer"},"parameters":["","\"StopPlayerFallingSpeed\""]}],"events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Snap player X position to the wall position","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"we check if the skin was flipped or not, and based on that we know at what direction the player is climbing\nthen we change the player X position to the raycast (in the event above) variable, to snap the player to the wall perfectly without leaving any gab"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"inverted":true,"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"MettreX"},"parameters":["PlayerHitbox","=","PlayerRightWallCollisionXPosition-(PlayerHitbox.Width()-6)"]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"MettreX"},"parameters":["PlayerHitbox","=","PlayerLeftWallCollisionXPosition-6"]}]}],"parameters":[]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Jump"]},{"type":{"inverted":true,"value":"PlatformBehavior::IsOnFloor"},"parameters":["PlayerHitbox","PlatformerObject"]}],"actions":[{"type":{"value":"SetBooleanVariable"},"parameters":["PlayerCantPressJumpKeyWhileClimbing","True",""]}]}]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Stop falling speed","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the timer (started in the events above) is greater than 0 (means it started)\nthen we set the falling speed and current falling speed to 0 (to stop the plaeyr from falling, since he is climbing now)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CompareTimer"},"parameters":["","\"StopPlayerFallingSpeed\"",">","0"]}],"actions":[{"type":{"value":"PlatformBehavior::MaxFallingSpeed"},"parameters":["PlayerHitbox","PlatformerObject","=","0",""]},{"type":{"value":"PlatformBehavior::PlatformerObjectBehavior::SetCurrentFallSpeed"},"parameters":["PlayerHitbox","PlatformerObject","=","0"]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the timer is greater or equal to 0.05 seconds\nthen we delete the timer (so we gave this event 0.05 seconds to update the player current and max falling speed)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CompareTimer"},"parameters":["","\"StopPlayerFallingSpeed\"",">=","0.05"]}],"actions":[{"type":{"value":"RemoveTimer"},"parameters":["","\"StopPlayerFallingSpeed\""]}]}],"parameters":[]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Disable","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if climb key (Z by default)\nwe set the climb variable to false (means player can press the climb key again)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextReleased"},"parameters":["","GameData.Controls.Climb"]}],"actions":[{"type":{"value":"SetBooleanVariable"},"parameters":["CantPressClimbKey","False",""]}],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if player was climbing (variable is true)\nwe reset the player max falling speed to 400 (default)\nand we set the climbing variable to false (measn the player is not climbing anymore)\nandwe set the plaeyr animation to fall\nand we forbid the player from air jump (in case he had an air jump)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","True",""]}],"actions":[{"type":{"value":"PlatformBehavior::MaxFallingSpeed"},"parameters":["PlayerHitbox","PlatformerObject","=","400",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","False",""]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["PlayerSkin","Animation","=","\"Fall\""]},{"type":{"value":"PlatformBehavior::PlatformerObjectBehavior::SetCanNotAirJump"},"parameters":["PlayerHitbox","PlatformerObject"]}]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Jump to other side","source":"","type":"BuiltinCommonInstructions::Group","events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Player is on Right wall","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if climb key is pressed (Z by default)\nand left key is pressed\nand Right key and Up key is not pressed\nand skin was not flipped horizontally (looking right)\nand player was climbing (variable is true)\nand player was not climbing on ledge (variable is false)\nand player is not dead (variable is false)\nand player was not jumping from a wall to another or wall jumping (variables are false)\nwe change skin animation to LookingToOtherDirectionWhileSlidingOnWall"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Climb"]},{"type":{"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Left"]},{"type":{"inverted":true,"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Right"]},{"type":{"inverted":true,"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Up"]},{"type":{"inverted":true,"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","True",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","ClimbingOnLedge","False",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","=",""]},{"type":{"value":"BooleanVariable"},"parameters":["IsJumpingFromWallToAnother","False",""]},{"type":{"value":"BooleanVariable"},"parameters":["IsJumpingFromRightWallToLeft","False",""]}],"actions":[{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["PlayerSkin","Animation","=","\"LookingToOtherDirectionWhileSlidingOnWall\""]}],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if jump key is pressed (C by default)\nwe reset the player max falling speed abck to 400 (default)\nand we set the climbing variable to false (means player is not climbing anymore)\nand we set the jumping from wall to another and from right wall to left variables to true\nand player is not jumping while climbing (variable is false)\nthen we allow the player to jump again\nand we set the player jump speed to 360 (default)\nand we delete the timer (used to check if player was wall jumping)\nthen we simualte pressing Right for player (this will make the Advanced platformer extension do the wall jump since Jump is pressed and moving right is pressed as well)\nthen we set the cat create jumping particles to true (to not allow creating jumping particles since the player is now in air)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Jump"]}],"actions":[{"type":{"value":"PlatformBehavior::MaxFallingSpeed"},"parameters":["PlayerHitbox","PlatformerObject","=","400",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","False",""]},{"type":{"value":"SetBooleanVariable"},"parameters":["IsJumpingFromWallToAnother","True",""]},{"type":{"value":"SetBooleanVariable"},"parameters":["IsJumpingFromRightWallToLeft","True",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","JumpingWhileClimbing","False",""]},{"type":{"value":"PlatformBehavior::SetCanJump"},"parameters":["PlayerHitbox","PlatformerObject"]},{"type":{"value":"PlatformBehavior::JumpSpeed"},"parameters":["PlayerHitbox","PlatformerObject","=","360"]},{"type":{"value":"RemoveTimer"},"parameters":["","\"StartCheckingIfPlayerIsWallJumping\""]},{"type":{"value":"PlatformBehavior::SimulateControl"},"parameters":["PlayerHitbox","PlatformerObject","\"Right\""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","CantCreateJumpingParticles","True",""]}],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"we create the landing particles at player position and set its angle and its gravity (game feel)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"Create"},"parameters":["","LandingParticles","PlayerHitbox.CenterX()+5","PlayerHitbox.BoundingBoxBottom()-10",""]},{"type":{"value":"SetAngle"},"parameters":["LandingParticles","=","-135"]},{"type":{"value":"ChangePlan"},"parameters":["LandingParticles","=","PlayerSkin.ZOrder()+1"]},{"type":{"value":"ParticleSystem::ParticleGravityX"},"parameters":["L