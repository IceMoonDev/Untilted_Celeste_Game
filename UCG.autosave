90","180","","\"linear\"","0.05"]},{"type":{"value":"SetNumberObjectVariable"},"parameters":["PlayerHitbox","IsAtStage","=","3"]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","Freeze","True",""]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::PauseAnimation"},"parameters":["PlayerSkin","Animation"]},{"type":{"value":"ChangeLayerTimeScale"},"parameters":["","","0.1"]},{"type":{"value":"SetBooleanVariable"},"parameters":["RemoveAllCameraShakes","True","\"\""]},{"type":{"value":"SetBooleanVariable"},"parameters":["MoveCameraTemporary","False",""]}]}],"parameters":[]}]}],"parameters":[]}],"parameters":[]}],"parameters":[]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Creating Spikes","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"This events is made to make level building much easier and smoother, rather than creating the Spikes instances in the editor 1 by 1 and having so much lag in the editor.\nwe use this events to auto draw the Spikes objects based on the tile sprite DrawSpikes object width and height, so rather than creating the Spikes instances 1 by 1 in the editor, we use DrawSpikes tiled sprite and we just scale its width and height, and this events will auto create Spikes based on the width and height of the tiled sprite."},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"at the beginning ofthe scene\nwe repeat the event 1000 time (just a big number to make the events below run as fast as possible (in 1 frame))"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"DepartScene"},"parameters":[""]}],"actions":[],"events":[{"type":"BuiltinCommonInstructions::Repeat","repeatExpression":"1000","conditions":[],"actions":[],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"for each DrawSpikes object"},{"type":"BuiltinCommonInstructions::ForEach","object":"DrawSpikes","conditions":[],"actions":[],"events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Spikes at 0 & 180 angle","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"when the spike is at 0 or 180 angle (right or left angle) we use the variable LoopOnX"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BuiltinCommonInstructions::Or"},"parameters":[],"subInstructions":[{"type":{"value":"Angle"},"parameters":["DrawSpikes","=","0"]},{"type":{"value":"Angle"},"parameters":["DrawSpikes","=","180"]}]}],"actions":[],"events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["DrawSpikes","CreatingGoldCompleted","=",""]},{"type":{"value":"NumberObjectVariable"},"parameters":["DrawSpikes","LoopOnX","<","round(DrawSpikes.Width()/10)"]}],"actions":[{"type":{"value":"Create"},"parameters":["","Spikes","DrawSpikes.X() + (DrawSpikes.LoopOnX * 10)","DrawSpikes.Y() + (DrawSpikes.LoopOnY * 10)",""]},{"type":{"value":"ChangePlan"},"parameters":["Spikes","=","1"]},{"type":{"value":"SetNumberObjectVariable"},"parameters":["DrawSpikes","LoopOnX","+","1"]},{"type":{"value":"SetAngle"},"parameters":["Spikes","=","DrawSpikes.Angle()"]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the variable LoopOnX is less than the DrawSpikes.Width/10 (we use this variable to check if creating Spikes horizontally has finished or not) (/10 because the Spikes object size is 10x10)\nthen we set the object variable of that instance to true (to stop the events above once and for all for this instance)\nand then we delete the DrawSpikes object (no longer needed, since all Spikes has been created)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberObjectVariable"},"parameters":["DrawSpikes","LoopOnX","=","round(DrawSpikes.Width()/10)"]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["DrawSpikes","CreatingGoldCompleted","True","1"]},{"type":{"value":"Delete"},"parameters":["DrawSpikes",""]}]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Spikes at -90 & 90 angle","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"same as above but for different angle\nso -90 and 90 is actualy Up and Down, so its a vertical spikes, and thats why in this events we use LoopOnY variable, while in the events above, use used LoopOnX"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BuiltinCommonInstructions::Or"},"parameters":[],"subInstructions":[{"type":{"value":"Angle"},"parameters":["DrawSpikes","=","-90"]},{"type":{"value":"Angle"},"parameters":["DrawSpikes","=","90"]}]}],"actions":[],"events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["DrawSpikes","CreatingGoldCompleted","=",""]},{"type":{"value":"NumberObjectVariable"},"parameters":["DrawSpikes","LoopOnY","<","round(DrawSpikes.Width() / 10)"]}],"actions":[{"type":{"value":"Create"},"parameters":["","Spikes","DrawSpikes.X()+((DrawSpikes.Width()-DrawSpikes.Height())/2)","DrawSpikes.Y()-((DrawSpikes.Width()-DrawSpikes.Height())/2)+(DrawSpikes.LoopOnY * 10)",""]},{"type":{"value":"ChangePlan"},"parameters":["Spikes","=","1"]},{"type":{"value":"SetNumberObjectVariable"},"parameters":["DrawSpikes","LoopOnY","+","1"]},{"type":{"value":"SetAngle"},"parameters":["Spikes","=","DrawSpikes.Angle()"]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberObjectVariable"},"parameters":["DrawSpikes","LoopOnY","=","round(DrawSpikes.Width() / 10)"]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["DrawSpikes","CreatingGoldCompleted","True","1"]},{"type":{"value":"Delete"},"parameters":["DrawSpikes",""]}]}]}],"parameters":[]}]}]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"disabled":true,"folded":true,"name":"Apple mechanics","source":"","type":"BuiltinCommonInstructions::Group","events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"UI","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"TextContainerCapability::TextContainerBehavior::SetValue"},"parameters":["ApplesCounterText","Text","=","\"x \"+ApplesScore"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Original position","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"at the beginning of the scene\nwe save the Original X and Y position for every apple in the level (we will use this variables to move the apple back to its original position if the player died while the apple was following the player(not collected))"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"DepartScene"},"parameters":[""]}],"actions":[{"type":{"value":"SetNumberObjectVariable"},"parameters":["Apple","OriginalXPosition","=","Apple.X()"]},{"type":{"value":"SetNumberObjectVariable"},"parameters":["Apple","OriginalYPosition","=","Apple.Y()"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Player died while apple is following","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the apple follow player variable was true (means the apple was following the player)\nand the player was dead (variable is true)\nand apple tween does not exist\nthen we tween the apple position back to its origina X and Y position that is stored in the variables"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["Apple","FollowPlayer","True",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","True",""]},{"type":{"inverted":true,"value":"Tween::Exists"},"parameters":["Apple","Tween","\"OriginalPosition\""]}],"actions":[{"type":{"value":"Tween::TweenBehavior::AddObjectPositionTween2"},"parameters":["Apple","Tween","\"OriginalPosition\"","Apple.OriginalXPosition","Apple.OriginalYPosition","\"easeInOutBack\"","0.5",""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"when the apple tween (started in the event above) has finished\nwe set the apple EllipseMovement behavior to Yes\nand we set the apple follow player variable to false\nand we set the player collecting variable to false (means the player is not collecting any apple anymore)\nand we remove the apple tweens"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"Tween::HasFinished"},"parameters":["Apple","Tween","\"OriginalPosition\""]}],"actions":[{"type":{"value":"ActivateBehavior"},"parameters":["Apple","EllipseMovement","yes"]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["Apple","FollowPlayer","False",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","CollectingApple","False",""]},{"type":{"value":"Tween::RemoveTween"},"parameters":["Apple","Tween","\"Up\""]},{"type":{"value":"Tween::RemoveTween"},"parameters":["Apple","Tween","\"OriginalPosition\""]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Return apple UI to their position","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the timer is greater or equal to 2 (started in the event below)\nwe tween the apple UI icon and text to the left side (outside the screen)\nthen we delete the timer (to trigger this event once everytime its called)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CompareTimer"},"parameters":["","\"ReturnUIAppleToOriginalPosition\"",">=","2"]}],"actions":[{"type":{"value":"Tween::TweenBehavior::AddObjectPositionXTween2"},"parameters":["AppleUIIcon","Tween","\"Left\"","-81","\"easeInBack\"","1",""]},{"type":{"value":"Tween::TweenBehavior::AddObjectPositionXTween2"},"parameters":["ApplesCounterText","Tween","\"Left\"","-34","\"easeInBack\"","1",""]},{"type":{"value":"RemoveTimer"},"parameters":["","\"ReturnUIAppleToOriginalPosition\""]}]}],"parameters":[]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if player was in collision with apple\nand the apple wasa not follow the player (variale is false)\nand the player didnt collect any apple (variable is false)\nand the player is not dead (variable is false)\nthen we disable the apple EllipseMovement\nand we set the apple FollowPlayer variable to true (means the apple is now following the player)\nand we set the player CollectingApple variable to true (means the player has collected an apple)\nthen we tween the apple scale to 1.4 (game feel)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CollisionNP"},"parameters":["PlayerHitbox","Apple","","","yes"]},{"type":{"value":"BooleanObjectVariable"},"parameters":["Apple","FollowPlayer","=",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","CollectingApple","=",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","=",""]}],"actions":[{"type":{"value":"ActivateBehavior"},"parameters":["Apple","EllipseMovement",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["Apple","FollowPlayer","True",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","CollectingApple","True",""]},{"type":{"value":"Tween::TweenBehavior::AddObjectScaleTween3"},"parameters":["Apple","Tween","\"Up\"","1.4","\"easeOutBack\"","0.05","","yes"]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"whenever the apple tween (started in the event above) has finished\nwe tween the apple scale back to 1 (default)\nand we remove the tween (to trigger this event everytime its called)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"Tween::HasFinished"},"parameters":["Apple","Tween","\"Up\""]}],"actions":[{"type":{"value":"Tween::TweenBehavior::AddObjectScaleTween3"},"parameters":["Apple","Tween","\"Default\"","1","\"linear\"","0.05","","yes"]},{"type":{"value":"Tween::RemoveTween"},"parameters":["Apple","Tween","\"Up\""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"whenever the follow player variable of the apple is true"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["Apple","FollowPlayer","True",""]}],"actions":[],"events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Follow player","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"we lerp the apple position to the player Center X/Y position"},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"MettreXY"},"parameters":["Apple","=","lerp(Apple.X(),PlayerHitbox.X(),0.03)","=","lerp(Apple.Y(),PlayerHitbox.Y(),0.03)"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Collect apple","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the player was not climbing on a ledge (variable is false)\nand the player was not dead (variable is false)\nand player was on floor\nand the raycast below the player is not in collosion with a spike (90 angle, means going down)\nthen we reset the apple variable to false (means the apple is not following the player anymore)\nand we then we create the apple particles on the apple position\nand we add 1 to the apples score\nthen we delete the apple\nand we set the player CollectingApples variable to false\nthen we wait 0.3 seconds (game feel)\nthen we move the Apple UI icon and the text to right (inside the screen for the player to see them)\nand we start the timer to return the UI apple icon and text to their position in the events above"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","ClimbingOnLedge","False",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","False",""]},{"type":{"value":"PlatformBehavior::IsOnFloor"},"parameters":["PlayerHitbox","PlatformerObject"]},{"type":{"value":"BuiltinCommonInstructions::Not"},"parameters":[],"subInstructions":[{"type":{"value":"Raycast"},"parameters":["Spikes","PlayerHitbox.CenterX()","PlayerHitbox.BoundingBoxBottom()","90","6","","",""]}]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["Apple","FollowPlayer","False",""]},{"type":{"value":"Create"},"parameters":["","AppleCollideEffect","Apple.CenterX()","Apple.CenterY()",""]},{"type":{"value":"Create"},"parameters":["","AppleCollectParticles","Apple.CenterX()","Apple.CenterY()",""]},{"type":{"value":"ChangePlan"},"parameters":["AppleCollideEffect","=","Apple.ZOrder()+1"]},{"type":{"value":"ChangePlan"},"parameters":["AppleCollectParticles","=","Apple.ZOrder()+1"]},{"type":{"value":"SetNumberVariable"},"parameters":["ApplesScore","+","1"]},{"type":{"value":"Delete"},"parameters":["Apple",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","CollectingApple","False",""]},{"type":{"value":"Wait"},"parameters":["0.3"]},{"type":{"value":"Tween::TweenBehavior::AddObjectPositionXTween2"},"parameters":["AppleUIIcon","Tween","\"Right\"","-16","\"easeOutBack\"","1",""]},{"type":{"value":"Tween::TweenBehavior::AddObjectPositionXTween2"},"parameters":["ApplesCounterText","Tween","\"Right\"","31","\"easeOutBack\"","1",""]},{"type":{"value":"ResetTimer"},"parameters":["","\"ReturnUIAppleToOriginalPosition\""]}]}],"parameters":[]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Trampoline mechanics","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"inverted":true,"value":"AnimatableCapability::AnimatableBehavior::Name"},"parameters":["Trampoline","Animation","=","\"Up\""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","=",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","=",""]},{"type":{"inverted":true,"value":"AdvancedJump::WallJump::IsAgaintWall"},"parameters":["PlayerHitbox","WallJump",""]},{"type":{"value":"CollisionNP"},"parameters":["PlayerHitbox","Trampoline","","","yes"]}],"actions":[{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["Trampoline","Animation","=","\"Up\""]},{"type":{"value":"ChangeSprite"},"parameters":["Trampoline","=","0"]},{"type":{"value":"PlatformBehavior::JumpSpeed"},"parameters":["PlayerHitbox","PlatformerObject","=","700"]},{"type