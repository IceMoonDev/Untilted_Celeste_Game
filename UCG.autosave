bjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"Left\""]}],"actions":[{"type":{"value":"PlatformBehavior::SimulateControl"},"parameters":["PlayerHitbox","PlatformerObject","\"Left\""]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Dashing up left","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"UpLeft\""]}],"actions":[{"type":{"value":"PlatformBehavior::SimulateControl"},"parameters":["PlayerHitbox","PlatformerObject","\"Left\""]}]}],"parameters":[]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Can dash again","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the player was not dashing (variable is false)\nand player cant dash again (variable is true)\nand the player was not climbing a wall (variable is false)\nand if the player was on floor or jumed on a trampoline (variable is true)\nthen we set the CantDash variable to false (means the player can dash again now)\nand we reset the colors for the skin"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDashing","False",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","CantDash","True",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","False",""]},{"type":{"value":"BuiltinCommonInstructions::Or"},"parameters":[],"subInstructions":[{"type":{"value":"PlatformBehavior::IsOnFloor"},"parameters":["PlayerHitbox","PlatformerObject"]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","JumpedOnTrampoline","True",""]}]}],"actions":[{"type":{"value":"SetBooleanObj