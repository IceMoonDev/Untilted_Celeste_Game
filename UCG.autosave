imation to Climbing"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","JumpingWhileClimbing","False",""]}],"actions":[{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["PlayerSkin","Animation","=","\"Climbing\""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if skin animation was Climbing and frame was equal to 2 or 5 then we play the climbing sound effect (2 and 5 frames have the characters hands on wall/climbing)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"AnimatableCapability::AnimatableBehavior::Name"},"parameters":["PlayerSkin","Animation","=","\"Climbing\""]},{"type":{"value":"BuiltinCommonInstructions::Or"},"parameters":[],"subInstructions":[{"type":{"value":"Sprite"},"parameters":["PlayerSkin","=","2"]},{"type":{"value":"Sprite"},"parameters":["PlayerSkin","=","5"]}]},{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"PlaySound"},"parameters":["","ClimbingSoundEffect","","28","RandomFloatInRange(0.8,1.1)"]}]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Climbing down","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if Down key is pressed\nand player was not exhausted (variable is false)\nand the raycast didnt collide with the floor below the player\nwe add fordce to the player at 90 angle (to bottom) at 120 speed"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Down"]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","Exhausted","False",""]},{"type":{"value":"BuiltinCommonInstructions::Not"},