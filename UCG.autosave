meters":["PlayerHitbox","IsClimbing","False",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","Exhausted","False",""]},{"type":{"value":"RemoveObjectTimer"},"parameters":["PlayerHitbox","\"StopFirstTintFlash\""]},{"type":{"value":"Flash::FlashColor::Stop"},"parameters":["PlayerSkin","FlashColor",""]},{"type":{"value":"SetNumberVariable"},"parameters":["ExhaustedMeter","=","0"]},{"type":{"value":"ChangePlan"},"parameters":["PlayerSkin","=","6"]}],"events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"inverted":true,"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"Tween::TweenBehavior::AddObjectPositionTween2"},"parameters":["PlayerHitbox","Tween","\"DeathToLeftSide\"","PlayerHitbox.X()-30","PlayerHitbox.Y()-22","\"easeOutSine\"","0.2",""]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"Tween::TweenBehavior::AddObjectPositionTween2"},"parameters":["PlayerHitbox","Tween","\"DeathToRightSide\"","PlayerHitbox.X()+30","PlayerHitbox.Y()-22","\"easeOutSine\"","0.2",""]}]}]}],"parameters":[]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Level 3","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["LevelNumber","=","3"]}],"actions":[],"events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Stage 1 & 3","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BuiltinCommonInstructions::Or"},"parameters":[],"subInstructions":[{"type":{"value":"NumberObjectVariable"},"parameters":["PlayerHitbox","IsAtStage","=","1"]},{"type":{"value":"NumberObjectVariable"},"parameters":["PlayerHitbox","IsAtStage","=","3"]}]},{"type":{"value":"PosY"},"parameters":["PlayerHitbox",">=","368"]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","=",""]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","True",""]},{"type":{"value":"ActivateBehavior"},"parameters":["PlayerHitbox","PlatformerObject",""]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["PlayerSkin","Animation","=","\"Death\""]},{"type":{"value":"CameraShake::ShakeCamera"},"parameters":["","0.2","0","0",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","False",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","Exhausted","False",""]},{"type":{"value":"RemoveObjectTimer"},"parameters":["PlayerHitbox","\"StopFirstTintFlash\""]},{"type":{"value":"Flash::FlashColor::Stop"},"parameters":["PlayerSkin","FlashColor",""]},{"type":{"value":"SetNumberVariable"},"parameters":["ExhaustedMeter","=","0"]},{"type":{"value":"ChangePlan"},"parameters":["PlayerSkin","=","6"]}],"events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"inverted":true,"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"Tween::TweenBehavior::AddObjectPositionTween2"},"parameters":["PlayerHitbox","Tween","\"DeathToLeftSide\"","PlayerHitbox.X()-30","PlayerHitbox.Y()-22","\"easeOutSine\"","0.2",""]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"Tween::TweenBehavior::AddObjectPositionTween2"},"parameters":["PlayerHitbox","Tween","\"DeathToRightSide\"","PlayerHitbox.X()+30","PlayerHitbox.Y()-22","\"easeOutSine\"","0.2",""]}]}]}],"parameters":[]}]}],"parameters":[]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"disabled":true,"name":"Death effect","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the death particles variable was true (set from the events belwo this one)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","ShowDeathParticles","True",""]}],"actions":[],"events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Death effect","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the StartStep2 variable is false (means creating death particles is still in step 1)\nand the DeathParticlesDistance is less than 45 (the distance between the death particles and the player center X/Y)\nthen we add 2 (this will increase the distance smoothly)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanVariable"},"parameters":["StartStep2FromDeathEffect","False",""]},{"type":{"value":"NumberVariable"},"parameters":["DeathParticlesDistance","<","45"]}],"actions":[{"type":{"value":"SetNumberVariable"},"parameters":["DeathParticlesDistance","+","2"]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"when the distance is greater or equal to 45\nand there is not transitions playing\nwe wait 0.08 seconds (game feel, to give time for the player to see the character)\nthen we tween the player death effect scale to 0.1\nand we start the death effect timer"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["DeathParticlesDistance",">=","45"]},{"type":{"value":"SceneInstancesCount"},"parameters":["","ReplayTransition","=","0"]},{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"Wait"},"parameters":["0.08"]},{"type":{"value":"Tween::TweenBehavior::AddObjectScaleTween3"},"parameters":["PlayerDeathEffect","Tween","\"Small\"","0.1","\"easeInBack\"","1","no","yes"]},{"type":{"value":"ResetTimer"},"parameters":["","\"StartDeathEffect\""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"we animate 8 copies of player death effect and make them orbit around the player (using orbit extension)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"OrbitingObjects::AnimateOrbitingObjects"},"parameters":["","PlayerHitbox","PlayerDeathEffect","8","55","DeathParticlesDistance","0","","PlayerSkin.ZOrder()+1","0","",""]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Sound effect","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"whenever the death timer is greater or equal to 0.35\nwe play the sound effect"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CompareTimer"},"parameters":["","\"StartDeathEffectStep2\"",">=","0.35"]},{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"PlaySound"},"parameters":["","assets\\Death3.wav","","40","1"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Death effect system steps","source":"","type":"BuiltinCommonInstructions::Group","events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Step 1","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if player is dead (variable is true)\nand the timer was greater or equal to 0.4 seconds\nor the jump key is pressed (so if the player pressed jump key, we immediatly skip the death animation waiting and start the replay transition to avoid the player waiting to respawn, this will make him respawn faster)\nand there is no replay transition playing\nand the skin was visible\nand the timer was not greater or equal to 0.25 (means the timer didnt start yet)\nthen we create and play the replay transition\nand we start the DeathEffectStep2 timer\nand we delete the Death effect timer"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","True",""]},{"type":{"value":"BuiltinCommonInstructions::Or"},"parameters":[],"subInstructions":[{"type":{"value":"CompareTimer"},"parameters":["","\"StartDeathEffect\"",">=","0.4"]},{"type":{"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Jump"]}]},{"type":{"value":"SceneInstancesCount"},"parameters":["","ReplayTransition","=","0"]},{"type":{"value":"Visible"},"parameters":["PlayerSkin"]},{"type":{"inverted":true,"value":"CompareTimer"},"parameters":["","\"DeathEffectStep2\"",">=","0.25"]},{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"Create"},"parameters":["","ReplayTransition","0","0","\"UI\""]},{"type":{"value":"FlashTransitionPainter::FlashTransitionPainter::PaintEffect"},"parameters":["ReplayTransition","FlashTransitionPainter","\"0;0;0\"","0.9","\"Horizontal\"","\"Both\"","",""]},{"type":{"value":"ResetTimer"},"parameters":["","\"StartDeathEffectStep2\""]},{"type":{"value":"RemoveTimer"},"parameters":["","\"StartDeathEffect\""]},{"type":{"value":"ChangePlan"},"parameters":["ReplayTransition","=","100"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Step 2","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the timer (started in the event above) is greater or equal to 0.45 seconds (which is 0.9/2 =0.45 because the transition in the event above direction is \"Both\" and we want this event here to happen as soon as the screen got coverd)\nthen we change the player position ot Last standing X/Y position (refer to \"Last standing position\" group event above)\nand we set the death effect step2 variable to true (to start step 2 from the death effect system in the events below this one)\nthen we stop the tween and remove it from the death effects\nand we reset the death effect scale back to 1\nthen we start step 2 timer\nand we delete the StartDeathEffectStep2 timer (to trigger this event once everytime its called)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CompareTimer"},"parameters":["","\"StartDeathEffectStep2\"",">=","0.45"]},{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"MettreXY"},"parameters":["PlayerHitbox","=","PlayerLastStandingXPosition","=","PlayerLastStandingYPosition"]},{"type":{"value":"SetBooleanVariable"},"parameters":["StartStep2FromDeathEffect","True",""]},{"type":{"value":"Tween::StopTween"},"parameters":["PlayerDeathEffect","Tween","\"Small\"","yes"]},{"type":{"value":"Tween::RemoveTween"},"parameters":["PlayerDeathEffect","Tween","\"Small\""]},{"type":{"value":"ScalableCapability::ScalableBehavior::SetValue"},"parameters":["PlayerDeathEffect","Scale","=","1"]},{"type":{"value":"ResetTimer"},"parameters":["","\"DeathEffectStep2\""]},{"type":{"value":"RemoveTimer"},"parameters":["","\"StartDeathEffectStep2\""]}],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the raycast at angle 180 (to left) is in collision with Traps group (Spikes, trampoline) then we add 4 to player position (this helps to avoid the player from respawning on a trampoline or a spike)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"Raycast"},"parameters":["Traps","PlayerHitbox.CenterX()","PlayerHitbox.BoundingBoxBottom()","180","20","","",""]}],"actions":[{"type":{"value":"MettreX"},"parameters":["PlayerHitbox","+","4"]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"same as above but for angle 0 (to right)\nand we subtract 4 in this case (to move the player to left (away from the trap on the right))"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"Raycast"},"parameters":["Traps","PlayerHitbox.CenterX()","PlayerHitbox.BoundingBoxBottom()","0","20","","",""]}],"actions":[{"type":{"value":"MettreX"},"parameters":["PlayerHitbox","-","4"]}]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Step 3","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if step 2 variable is true (set from the event above)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanVariable"},"parameters":["StartStep2FromDeathEffect","True",""]}],"actions":[],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if particles distance variable is greater than 0\nand timer is greater or equal to 0.25seconds\nthen we subtract 2 (so, create particles → increase their distance → decrease their distance)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["DeathParticlesDistance",">","0"]},{"type":{"value":"CompareTimer"},"parameters":["","\"DeathEffectStep2\"",">=","0.25"]}],"actions":[{"type":{"value":"SetNumberVariable"},"parameters":["DeathParticlesDistance","-","2"]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"once the distance is less or equal to 0\nwe reset the skin zo rder back to 5 (default)\nand we set the animation back to Idle\nand Dead variable to false (means the player is not dead anymore)\nand we turn on the platformer behavior\nand we set the current horizontal speed to 0 (to stop the player movement after respawning)\nand we reset the variables back to false\nand we delete the timer\nand we abort any jump for the player\nand we reset the max falling speed and jump speed to default values\nthen we reset the dashing varibale to false (in case the player was dashing we stop it)\nthen we wait 0.01 seconds and finally we delete the death effect objects"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["DeathParticlesDistance","<=","0"]}],"actions":[{"type":{"value":"ChangePlan"},"parameters":["PlayerSkin","=","5"]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["PlayerSkin","Animation","=","\"Idle\""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","False",""]},{"type":{"value":"ActivateBehavior"},"parameters":["PlayerHitbox","PlatformerObject","yes"]},{"type":{"value":"PlatformBehavior::PlatformerObjectBehavior::SetCurrentSpeed"},"parameters":["PlayerHitbox","PlatformerObject","=","0"]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","ShowDeathParticles","False",""]},{"type":{"value":"SetNumberVariable"},"parameters":["DeathParticlesDistance","=","0"]},{"type":{"value":"SetBooleanVariable"},"parameters":["StartStep2FromDeathEffect","False",""]},{"type":{"value":"RemoveTimer"},"parameters":["","\"DeathEffectStep2\""]},{"type":{"value":"PlatformBehavior::PlatformerObjectBehavior::AbortJump"},"parameters":["PlayerHitbox","PlatformerObject"]},{"type":{"value":"PlatformBehavior::MaxFallingSpeed"},"parameters":["PlayerHitbox","PlatformerObject","=","400",""]},{"type":{"value":"PlatformBehavior::JumpSpeed"},"parameters":["PlayerHitbox","PlatformerObject","=","360"]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","IsDashing","False",""]},{"type":{"value":"Wait"},"parameters":["0.01"]},{"type":{"value":"Delete"},"parameters":["PlayerDeathEffect",""]}]}]}],"parameters":[]}],"parameters":[]}]}],"parameters":[]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"AnimatableCapability::AnimatableBehavior::Name"},"parameters":["PlayerSkin","Animation","=","\"Death\""]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::HasAnimationEnded"},"parameters":["PlayerSkin","Animation"]},{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"SetLayerEffectParameter"},"parameters":["","","\"Shockwave\"","\"centerX\"","(PlayerHitbox.CenterX()-(CameraCenterX()-(SceneWindowWidth()/2)))/SceneWindowWidth()"]},{"type":{"value":"SetLayerEffectParameter"},"parameters":["","","\"Shockwave\"","\"centerY\"","(PlayerHitbox.CenterY()-(CameraCenterY()-(SceneWindowHeight()/2)))/SceneWindowHeight()"]},{"type":{"value":"SetLayerEffectParameter"},"parameters":["","","\"Shockwave\"","\"time\"","0.15"]},{"type":{"value":"SetLayerEffectParameter"},"parameters":["","","\"Shockwave\"","\"radius\"","80"]},{"type":{"value":"EnableLayerEffect"},"parameters":["","","\"Shockwave\"","yes"]},{"type":{"value":"CameraShake::ShakeCamera"},"parameters":["","0.2","0","0",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","ShowDeathParticles","True",""]}],"events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Save number of player death","source":"","type":"BuiltinCommonInstructions::Group","events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"