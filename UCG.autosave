e"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["ShadowsCounter","<","4"]},{"type":{"value":"BuiltinCommonInstructions::Or"},"parameters":[],"subInstructions":[{"type":{"value":"CompareObjectTimer"},"parameters":["PlayerHitbox","\"CreateDashShadows\"",">=","0.06"]},{"type":{"value":"BuiltinCommonInstructions::CompareNumbers"},"parameters":["DistanceBetweenPositions(PlayerHitbox.CenterX(),PlayerHitbox.CenterY(),PlayerSavedXPositionForShadow,PlayerSavedYPositionForShadow)",">","32"]}]},{"type":{"value":"BuiltinCommonInstructions::Or"},"parameters":[],"subInstructions":[{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"Left\""]},{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"Right\""]},{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"DownRight\""]},{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"Down\""]},{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"DownLeft\""]},{"type":{"value":"BuiltinCommonInstructions::And"},"parameters":[],"subInstructions":[{"type":{"inverted":true,"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"Left\""]},{"type":{"inverted":true,"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"Right\""]},{"type":{"inverted":true,"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"DownRight\""]},{"type":{"inverted":true,"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"Down\""]},{"type":{"inverted":true,"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"DownLeft\""]},{"type":{"inverted":true,"value":"PlatformBehavior::IsOnFloor"},"parameters":["PlayerHitbox","PlatformerObject"]}]}]}],"actions":[{"type":{"value":"Create"},"parameters":["","PlayerShadow","PlayerSkin.X()-(PlayerSkin.Width()/2)","PlayerSkin.Y()-PlayerSkin.Height()",""]},{"type":{"value":"OpacityCapability::OpacityBehavior::SetValue"},"parameters":["PlayerShadow","Opacity","=","190"]},{"type":{"value":"ChangePlan"},"parameters":["PlayerShadow","=","PlayerSkin.ZOrder()-1"]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["PlayerShadow","Animation","=","PlayerSkin.Animation::Name()"]},{"type":{"value":"ChangeSprite"},"parameters":["PlayerShadow","=","PlayerSkin.Sprite()"]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::PauseAnimation"},"parameters":["PlayerShadow","Animation"]},{"type":{"value":"SetNumberVariable"},"parameters":["PlayerSavedXPositionForShadow","=","PlayerHitbox.CenterX()"]},{"type":{"value":"SetNumberVariable"},"parameters":["PlayerSavedYPositionForShadow","=","PlayerHitbox.CenterY()"]},{"type":{"value":"SetNumberVariable"},"parameters":["ShadowsCounter","+","1"]},{"type":{"value":"ResetObjectTimer"},"parameters":["PlayerHitbox","\"CreateDashShadows\""]},{"type":{"value":"ResizableCapability::ResizableBehavior::SetSize"},"parameters":["PlayerShadow","Resizable","PlayerSkin.Width()","PlayerSkin.Height()"]},{"type":{"value":"ScalableCapability::ScalableBehavior::SetX"},"parameters":["PlayerShadow","Scale","=","PlayerSkin.Scale::X()"]},{"type":{"value":"ScalableCapability::ScalableBehavior::SetY"},"parameters":["PlayerShadow","Scale","=","PlayerSkin.Scale::Y()"]}],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"based on the player flip direciont we flip the shadow"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"inverted":true,"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"FlippableCapability::FlippableBehavior::FlipX"},"parameters":["PlayerShadow","Flippable",""]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"FlippableCapability::FlippableBehavior::FlipX"},"parameters":["PlayerShadow","Flippable","yes"]}]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the sahdow counter was greater or equal to 3 (means all 3 shadows got created perfectly)\nwe set the create shadows back to false\nand we reset the counter variable back to 0\nand we delete the timer"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["ShadowsCounter",">=","3"]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","CreateShadows","False",""]},{"type":{"value":"SetNumberVariable"},"parameters":["ShadowsCounter","=","0"]},{"type":{"value":"RemoveObjectTimer"},"parameters":["PlayerHitbox","\"CreateDashShadows\""]}]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Remove","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"for every instance of the shadow object"},{"type":"BuiltinCommonInstructions::ForEach","object":"PlayerShadow","conditions":[],"actions":[],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the shadow opacity was greater than 0\nthen we subtract 8 from it (to smoothly fade out the shadow)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"OpacityCapability::OpacityBehavior::Value"},"parameters":["PlayerShadow","Opacity",">","0"]}],"actions":[{"type":{"value":"OpacityCapability::OpacityBehavior::SetValue"},"parameters":["PlayerShadow","Opacity","-","8"]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"whenever the shadow opacity is less or equal to 0\nthen we delete that shadow object"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"OpacityCapability::OpacityBehavior::Value"},"parameters":["PlayerShadow","Opacity","<=","0"]}],"actions":[{"type":{"value":"Delete"},"parameters":["PlayerShadow",""]}]}]}],"parameters":[]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"disabled":true,"folded":true,"name":"Particles","source":"","type":"BuiltinCommonInstructions::Group","events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Direction","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the player particles timer is greater or equal to 0.02 seconds\nand the dash particles counter variable is less than 10 (we used this variable to be able to create 10 instances only)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CompareObjectTimer"},"parameters":["PlayerHitbox","\"CreateDashParticles\"",">=","0.02"]},{"type":{"value":"NumberVariable"},"parameters":["DashParticlesCounter","<","10"]}],"actions":[],"events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Up","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the dash direction variable was Up (means player was dashing to up)\nthen we create dash particles object at player position\nand we set the angle to -90 (to top)\nand we change the X gravity as well (game feel)\nthen we reset the timer (to trigger this event again)\nand we add 1 to the counter variable"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"Up\""]}],"actions":[{"type":{"value":"Create"},"parameters":["","DashParticles","PlayerStartedCenterXPosition","PlayerHitbox.CenterY()",""]},{"type":{"value":"ChangePlan"},"parameters":["DashParticles","=","PlayerSkin.ZOrder()-1"]},{"type":{"value":"SetAngle"},"parameters":["DashParticles","=","-90"]},{"type":{"value":"ParticleSystem::ParticleGravityX"},"parameters":["DashParticles","=","RandomInRange(-40,40)"]},{"type":{"value":"ResetObjectTimer"},"parameters":["PlayerHitbox","\"CreateDashParticles\""]},{"type":{"value":"SetNumberVariable"},"parameters":["DashParticlesCounter","+","1"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Up right","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"same as above but for other dash direction"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"UpRight\""]}],"actions":[{"type":{"value":"Create"},"parameters":["","DashParticles","PlayerHitbox.CenterX()","PlayerHitbox.CenterY()",""]},{"type":{"value":"ChangePlan"},"parameters":["DashParticles","=","PlayerSkin.ZOrder()-1"]},{"type":{"value":"SetAngle"},"parameters":["DashParticles","=","-45"]},{"type":{"value":"ParticleSystem::ParticleGravityX"},"parameters":["DashParticles","=","RandomInRange(-40,40)"]},{"type":{"value":"ResetObjectTimer"},"parameters":["PlayerHitbox","\"CreateDashParticles\""]},{"type":{"value":"SetNumberVariable"},"parameters":["DashParticlesCounter","+","1"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Right","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value"