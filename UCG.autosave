n Climb button, will move you back to Controls button (2))"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["PauseMenuButtonsOrder","=","1"]},{"type":{"value":"BooleanVariable"},"parameters":["DisableTheNextEvent","=",""]}],"actions":[{"type":{"value":"SetNumberVariable"},"parameters":["PauseMenuButtonsOrder","=","5"]}]}],"variables":[{"name":"DisableTheNextEvent","type":"boolean","value":false}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Scrolling down","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"same as above but for scrolling down, so rather than subtracting 1, we add 1"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Down"]},{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]},{"type":{"value":"BooleanVariable"},"parameters":["ControlsMenuIsOpen","False",""]}],"actions":[],"events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["PauseMenuButtonsOrder","<","5"]}],"actions":[{"type":{"value":"SetNumberVariable"},"parameters":["PauseMenuButtonsOrder","+","1"]},{"type":{"value":"SetBooleanVariable"},"parameters":["DisableTheNextEvent","True",""]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["PauseMenuButtonsOrder","=","5"]},{"type":{"value":"BooleanVariable"},"parameters":["DisableTheNextEvent","=",""]}],"actions":[{"type":{"value":"SetNumberVariable"},"parameters":["PauseMenuButtonsOrder","=","1"]}]}],"variables":[{"name":"DisableTheNextEvent","type":"boolean","value":false}]}],"parameters":[]}],"parameters":[]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Trig