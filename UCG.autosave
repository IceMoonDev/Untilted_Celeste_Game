erHitbox.CenterY()",""]},{"type":{"value":"ChangePlan"},"parameters":["DashParticles","=","PlayerSkin.ZOrder()-1"]},{"type":{"value":"SetAngle"},"parameters":["DashParticles","=","90"]},{"type":{"value":"ParticleSystem::ParticleGravityX"},"parameters":["DashParticles","=","RandomInRange(-40,40)"]},{"type":{"value":"ResetObjectTimer"},"parameters":["PlayerHitbox","\"CreateDashParticles\""]},{"type":{"value":"SetNumberVariable"},"parameters":["DashParticlesCounter","+","1"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Down left","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"DownLeft\""]}],"actions":[{"type":{"value":"Create"},"parameters":["","DashParticles","PlayerHitbox.CenterX()","PlayerHitbox.CenterY()",""]},{"type":{"value":"ChangePlan"},"parameters":["DashParticles","=","PlayerSkin.ZOrder()-1"]},{"type":{"value":"SetAngle"},"parameters":["DashParticles","=","135"]},{"type":{"value":"ParticleSystem::ParticleGravityX"},"parameters":["DashParticles","=","RandomInRange(-40,40)"]},{"type":{"value":"ResetObjectTimer"},"parameters":["PlayerHitbox","\"CreateDashParticles\""]},{"type":{"value":"SetNumberVariable"},"parameters":["DashParticlesCounter","+","1"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Left","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"Left\""]}],"actions":[{"type":{"value":"Create"},"parameters":["","DashParticles","PlayerHitbox.CenterX()","PlayerHitbox.CenterY()",""]},{"type":{"value":"ChangePlan"},"parameters":["DashParticles","=","PlayerSkin.ZOrder()-1"]},{"type":{"value":"SetAngle"},"parameters":["DashParticles","=","180"]},{"type":{"value":"ParticleSystem::ParticleGravityX"},"parameters":["DashParticles","=","RandomInRange(-40,40)"]},{"type":{"value":"ResetObjectTimer"},"parameters":["PlayerHitbox","\"CreateDashParticles\""]},{"type":{"value":"SetNumberVariable"},"parameters":["DashParticlesCounter","+","1"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Up left","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"UpLeft\""]}],"actions":[{"type":{"value":"Create"},"parameters":["","DashParticles","PlayerHitbox.CenterX()","PlayerHitbox.CenterY()",""]},{"type":{"value":"ChangePlan"},"parameters":["DashParticles","=","PlayerSkin.ZOrder()-1"]},{"type":{"value":"SetAngle"},"parameters":["DashParticles","=","-135"]},{"type":{"value":"ParticleSystem::ParticleGravityX"},"parameters":["DashParticles","=","RandomInRange(-40,40)"]},{"type":{"value":"ResetObjectTimer"},"parameters":["PlayerHitbox","\"CreateDashParticles\""]},{"type":{"value":"SetNumberVariable"},"parameters":["DashParticlesCounter","+","1"]}]}],"parameters":[]}]}],"parameters":[]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"whenever the counter variable is greater or equal to 10\nthen we delete the dash particles timer\nand we reset the counter variable back to 0"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["DashParticlesCounter",">=","10"]}],"actions":[{"type":{"value":"RemoveObjectTimer"},"parameters":["PlayerHitbox","\"CreateDashParticles\""]},{"type":{"value":"SetNumberVariable"},"parameters":["DashParticlesCounter","=","0"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Crystal","source":"","type":"BuiltinCommonInstructions::Group","events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Particles + original position","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::ForEach","object":"DashCrystal","conditions":[],"actions":[],"events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Create","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["DashCrystal","ParticlesIsCreated","=",""]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["DashCrystal","ParticlesIsCreated","True",""]}],"events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"Create"},"parameters":["","CrystalParticles","DashCrystal.CenterX()","DashCrystal.CenterY()",""]},{"type":{"value":"LinkedObjects::LinkObjects"},"parameters":["","CrystalParticles","DashCrystal"]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"Create"},"parameters":["","CrystalParticles","DashCrystal.CenterX()","DashCrystal.CenterY()",""]},{"type":{"value":"LinkedObjects::LinkObjects"},"parameters":["","CrystalParticles","DashCrystal"]},{"type":{"value":"SetAngle"},"parameters":["CrystalParticles","=","90"]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"Create"},"parameters":["","CrystalParticles","DashCrystal.CenterX()","DashCrystal.CenterY()",""]},{"type":{"value":"LinkedObjects::LinkObjects"},"parameters":["","CrystalParticles","DashCrystal"]},{"type":{"value":"SetAngle"},"parameters":["CrystalParticles","=","180"]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"Create"},"parameters":["","CrystalParticles","DashCrystal.CenterX()","DashCrystal.CenterY()",""]},{"type":{"value":"LinkedObjects::LinkObjects"},"parameters":["","CrystalParticles","DashCrystal"]},{"type":{"value":"SetAngle"},"parameters":["CrystalParticles","=","-90"]}]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Update position","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["DashCrystal","ParticlesIsCreated","True",""]},{"type":{"value":"LinkedObjects::PickObjectsLinkedTo"},"parameters":["","CrystalParticles","DashCrystal",""]}],"actions":[{"type":{"value":"MettreXY"},"parameters":["CrystalParticles","=","DashCrystal.CenterX()","=","DashCrystal.CenterY()"]}]}],"parameters":[]}]}],"parameters":[]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if player cant dash (variable is true)\nwe pick the nearest crystal to the player (for better performance)\nand if the crystal animation was Active\nand palyer is in collision with crystal\nwe take into account crystal particles linked to the dash crystal\nthen we set the player cant dash variable to false (means the player can dash again now)\nand we reset the skin colors to default\nand we set the crystal animation to Inactive\nand we hide the particles linked to the crystal\nand we disable the glow effect on the crystal\nthen we set the time scale to 0.1 (slow it down, game feel)\nand we start the dash freeze timer (used to reset the layer time scale back to default)\nand we pause the dash finished timer\nand we create the Crystal collide effect object on the crystal position\nand we start the cooldown timer for the crystal (used to know when the crystal can become active again)\nand finally we disable the crystal EllipseMovement behaviour (used to make the crystal float up/down)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","CantDash","True",""]},{"type":{"value":"PickNearest"},"parameters":["DashCrystal","PlayerHitbox.CenterX()","PlayerHitbox.CenterY()",""]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::Name"},"parameters":["DashCrystal","Animation","=","\"Active\""]},{"type":{"value":"CollisionNP"},"parameters":["PlayerHitbox","DashCrystal","","",""]},{"type":{"value":"LinkedObjects::PickObjectsLinkedTo"},"parameters":["","CrystalParticles","DashCrystal",""]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","CantDash","False",""]},{"type":{"value":"Recolorizer::SpriteRecolorizer::ResetColor"},"parameters":["PlayerSkin","SpriteRecolorizer",""]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["DashCrystal","Animation","=","\"Inactive\""]},{"type":{"value":"Cache"},"parameters":["CrystalParticles"]},{"type":{"value":"EffectCapability::EffectBehavior::EnableEffect"},"parameters":["DashCrystal","Effect","\"Glow\"",""]},{"type":{"value":"ChangeLayerTimeScale"},"parameters":["","","0.1"]},{"type":{"value":"ResetTimer"},"parameters":["","\"DashFreeze\""]},{"type":{"value":"PauseTimer"},"parameters":["","\"DashFinished\""]},{"type":{"value":"Create"},"parameters":["","CrystalCollideEffect","DashCrystal.CenterX()","DashCrystal.CenterY()",""]},{"type":{"value":"ChangePlan"},"parameters":["CrystalCollideEffect","=","DashCrystal.ZOrder()+1"]},{"type":{"value":"ResetObjectTimer"},"parameters":["DashCrystal","\"Cooldown\""]},{"type":{"value":"ActivateBehavior"},"parameters":["DashCrystal","EllipseMovement",""]}]},{"type":"BuiltinCommonInstructions::ForEach","object":"DashCrystal","conditions":[{"type":{"value":"CompareObjectTimer"},"parameters":["DashCrystal","\"Cooldown\"",">=","2.5"]},{"type":{"value":"LinkedObjects::PickObjectsLinkedTo"},"parameters":["","CrystalParticles","DashCrystal",""]}],"actions":[{"type":{"value":"ActivateBehavior"},"parameters":["DashCrystal","EllipseMovement","yes"]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["DashCrystal","Animation","=","\"Active\""]},{"type":{"value":"Montre"},"parameters":["CrystalParticles",""]},{"type":{"value":"EffectCapability::EffectBehavior::EnableEffect"},"parameters":["DashCrystal","Effect","\"Glow\"","yes"]},{"type":{"value":"RemoveObjectTimer"},"parameters":["DashCrystal","\"Cooldown\""]},{"type":{"value":"ScalableCapability::ScalableBehavior::SetValue"},"parameters":["DashCrystal","Scale","=","1.6"]},{"type":{"value":"Tween::TweenBehavior::AddObjectScaleTween3"},"parameters":["DashCrystal","Tween","\"DefaultScale\"","1","\"easeOutBack\"","0.2","","yes"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"disabled":true,"folded":true,"name":"Fix player getting stuck when dashing LeftDown or RightDown on corners","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"If the player standed on a corcer (left bottom corner for example) and the dashed bottom left, the player will get stuck in the floor, and this events here fix this bug.\nif the player cant dash (variable is true)\nand player is not dead (variable is false)\nand if the player was dashing DownLeft or DownRight\nand player was falling\nand player was in collision with the level (floor/wall)\nthen we separate the player from the level"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","CantDash","True",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","=",""]},{"type":{"value":"BuiltinCommonInstructions::Or"},"parameters":[],"subInstructions":[{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"DownLeft\""]},{"type":{"value":"StringObjectVariable"},"parameters":["PlayerHitbox","DashDirection","=","\"DownRight\""]}]},{"type":{"value":"PlatformBehavior::IsFalling"},"parameters":["PlayerHitbox","PlatformerObject"]},{"type":{"value":"CollisionNP"},"parameters":["PlayerHitbox","AllLevelsCollisions","","","yes"]}],"actions":[{"type":{"value":"SeparateFromObjects"},"parameters":["PlayerHitbox","AllLevelsCollisions","yes"]}]}],"parameters":[]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextPressed"},"parameters":["","GameData.Controls.Dash"]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","CantDash","=",""]},{"type":{"value":"BooleanVariable"},"parameters":["CantUseDashKey","False",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","DashCooldownIsPlaying","=",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","=",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","Freeze","=",""]},{"type":{"value":"BooleanVariable"},"parameters":["LevelStarted","True",""]},{"type":{"value":"BooleanVariable"},"parameters":["PauseGame","False",""]},{"type":{"value":"BooleanVariable"},"parameters":["LevelIsFinished","=",""]}],"actions":[{"type":{"value":"SetBooleanVariable"},"parameters":["CantUseDashKey","True",""]}],"events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Direction","source":"","type":"BuiltinCommonInstructions::Group","events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"folded":true,"name":"Up","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if up key is pressed\nand other movement keys are not pressed\nwe change the player jump speed to 300 (more like the dash power/force)\nthen we set the player Dashing variable to True (means the player is now dashing)\nand we set the CantDash variable to true (means the player cant dash now)\nand we start the dash cooldown (variable is set to  true)\nthen we set the shockwave radius to 60\nand we set the Center X to player hitbox x - camera border left / camera width (this will return the exact position on the player center x position)\nsame but for center Y\nthen we set the time to 0.15 (to not start the shockwave completly from 0)\nthen we enable the shockwave effect\nthen we abort the player current jump (in case the player was jumping, we stop the jump)\nthen we change the max falling speed to 0\nand current falling speed to 0 (to stop any falling on the player)\nthen we allow the player to jump again\nand we simualte jump key for the player\nthen we set the layer time scale to 0.1 (slow down, game feel)\nthen we set the player dash direction variable to Up (since in this event we are dashing Up)\nthen we set the simualte movement variable to True (used to simualte movements for the player while dashing to keep the momentom (refer to \"Dash simulated movement keys\" group event))\nthen we add a force for the player at -90 angle (up)\nthen we start the Shadows timer (to create shadows for the player)\nand we start the dash finished and freeze timer\nthen we set the player saved shadows positions variable to 0 (to trigger the shadow events)\nthen we create shadows for the player (variable is true)\nthen we create the dash effect object at player position\nand we set the angle start and End to 0 \nand we set the player climbing variable to false (in case the player was climbing we stop it)\nthen we start the dash particles timer\nthen we set the player center X position variable to player center X position (used to create the dash particles at the right X position)\nthen we set the shake direction variable to Up (used to shake the camera to the right direction based on the player dash direction (game feel))\nthen we set the player colors to Aqua (using Recolorizer extension)\nand finally we disbale the WallJump behaviour in case the plaeyrw as climbing on a wall"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"KeyFromTextPressed"},"paramete