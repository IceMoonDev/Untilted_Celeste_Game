ype":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","StartForbidCreatingParticlesEvents","True",""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the forbid variable is true (set from the event above)\nand player was falling\nthen we set the variable back to false (to not allow the event above from running)\nbasiaclly: this events is to stop the player from creating landing particles when the game has just started"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","StartForbidCreatingParticlesEvents","True",""]},{"type":{"value":"PlatformBehavior::IsFalling"},"parameters":["PlayerHitbox","PlatformerObject"]},{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","CantCreateLandingParticles","False",""]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Falling time","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if player was not climbing (variable was false)\nif player was falling\nand the timer was not greater than 0 (means the timer didnt start yet)\nthen we start the player falling timer"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","=",""]},{"type":{"value":"PlatformBehavior::IsFalling"},"parameters":["PlayerHitbox","PlatformerObject"]},{"type":{"inverted":true,"value":"CompareObjectTimer"},"parameters":["PlayerHitbox","\"FallingTime\"",">","0"]}],"actions":[{"type":{"value":"ResetObjectTimer"},"parameters":["PlayerHitbox","\"FallingTime\""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the timer started in the event above is greater than 0.2 seconds\nthen we set the can create landing particles to true (used to tell if the player can create landing particles or not)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CompareObjectTimer"},"parameters":["PlayerHitbox","\"FallingTime\"",">","0.2"]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","CanCreateLandingParticles","True",""]}]},{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if the timer is less than 0.2 seconds\nand player was on floor\nthen we set the CanCreateLandingParticles variable to false (means the player cant create the landing particles now)\nthen we delete the timer\nBasiaclly: this events are used to controll when to let the player create landing particles"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CompareObjectTimer"},"parameters":["PlayerHitbox","\"FallingTime\"","<","0.2"]},{"type":{"value":"PlatformBehavior::IsOnFloor"},"parameters":["PlayerHitbox","PlatformerObject"]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","CanCreateLandingParticles","False",""]},{"type":{"value":"RemoveObjectTimer"},"parameters":["PlayerHitbox","\"FallingTime\""]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Create","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if player is on floor\nand player was not climbing on the ledge (variable is false)\nand player can create landing particles (variable is false)\nand player was not climbing (variable is false)\nand player cant create jumping particles (variable is true)\nand player was not dead (variable is false)\nthen we delete the falling timer\nthen we set the particles variables to false"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"PlatformBehavior::IsOnFloor"},"parameters":["PlayerHitbox","PlatformerObject"]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","ClimbingOnLedge","=",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","CantCreateLandingParticles","=",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","=",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","CantCreateJumpingParticles","True",""]},{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","=",""]},{"type":{"value":"BuiltinCommonInstructions::Once"},"parameters":[]}],"actions":[{"type":{"value":"RemoveObjectTimer"},"parameters":["PlayerHitbox","\"FallingTime\""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","CanCreateLandingParticles","False",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","CantCreateJumpingParticles","False",""]}],"events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"we just create 2 landing particles each with its own angle and X gravity (game feel)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"Create"},"parameters":["","LandingParticles","PlayerHitbox.CenterX()+5","PlayerHitbox.BoundingBoxBottom()",""]},{"type":{"value":"SetAngle"},"parameters":["LandingParticles","=","315"]},{"type":{"value":"ChangePlan"},"parameters":["LandingParticles","=","PlayerSkin.ZOrder()+1"]},{"type":{"value":"ParticleSystem::ParticleGravityX"},"parameters":["LandingParticles","=","20"]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"Create"},"parameters":["","LandingParticles","PlayerHitbox.CenterX()-5","PlayerHitbox.BoundingBoxBottom()",""]},{"type":{"value":"SetAngle"},"parameters":["LandingParticles","=","225"]},{"type":{"value":"ChangePlan"},"parameters":["LandingParticles","=","PlayerSkin.ZOrder()+1"]},{"type":{"value":"ParticleSystem::ParticleGravityX"},"parameters":["LandingParticles","=","-20"]}]}]}],"parameters":[]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Death","source":"","type":"BuiltinCommonInstructions::Group","events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Last standing position","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","=",""]},{"type":{"value":"Raycast"},"parameters":["AllLevelsCollisions","PlayerHitbox.CenterX()","PlayerHitbox.BoundingBoxBottom()","90","1","","",""]},{"type":{"value":"BuiltinCommonInstructions::Not"},"parameters":[],"subInstructions":[{"type":{"value":"Raycast"},"parameters":["Trampoline","PlayerHitbox.CenterX()","PlayerHitbox.BoundingBoxBottom()","90","1","","",""]}]},{"type":{"inverted":true,"value":"CollisionNP"},"parameters":["PlayerHitbox","Spikes","","","yes"]}],"actions":[{"type":{"value":"SetNumberVariable"},"parameters":["PlayerLastStandingXPosition","=","PlayerHitbox.X()"]},{"type":{"value":"SetNumberVariable"},"parameters":["PlayerLastStandingYPosition","=","PlayerHitbox.Y()"]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"From spikes","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Comment","color":{"b":109,"g":230,"r":255,"textB":0,"textG":0,"textR":0},"comment":"if player is not dead (variable is false)\nand player is in collision with spikes\nthen we set the player IsDead variable to true (means the player is now dead)\nthen we disable the platformer behavior of the player\nand we set the skin animation to Death\nthen we shake the camera (game feel)\nthen we set the Climbing and Exhausted variables to false (to stop the player from climbing in case he was, and to stop the exhausted system as well)\nand we delete the TintFlash timer (used to flash the skin into red)\nand we setop flasing the skin\nthen we set the exhausted meter variable back to 0 (so if the player has died, the exhausted meter should reset)\nthen we set the skin z order to 6 (above the map zorde, so the player can see the skin death animation rather than the skin going below the map walls/floor)"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","=",""]},{"type":{"value":"CollisionNP"},"parameters":["PlayerHitbox","Spikes","","","yes"]}],"actions":[{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","True",""]},{"type":{"value":"ActivateBehavior"},"parameters":["PlayerHitbox","PlatformerObject","no"]},{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["PlayerSkin","Animation","=","\"Death\""]},{"type":{"value":"CameraShake::ShakeCamera"},"parameters":["","0.2","0","0",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","IsClimbing","False",""]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["PlayerHitbox","Exhausted","False",""]},{"type":{"value":"RemoveObjectTimer"},"parameters":["PlayerHitbox","\"StopFirstTintFlash\""]},{"type":{"value":"Flash::FlashColor::Stop"},"parameters":["PlayerSkin","FlashColor",""]},{"type":{"value":"SetNumberVariable"},"parameters":["ExhaustedMeter","=","0"]},{"type":{"value":"ChangePlan"},"parameters":["PlayerSkin","=","6"]}],"events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"inverted":true,"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"Tween::TweenBehavior::AddObjectPositionTween2"},"parameters":["PlayerHitbox","Tween","\"DeathToLeftSide\"","PlayerHitbox.XFromAngleAndDistance(\n  AngleBetweenPositions(PlayerHitbox.CenterX(), PlayerHitbox.CenterY(), Spikes.CenterX(), Spikes.CenterY()) + 180 + RandomInRange(-10, 10),\n  50\n)\n","PlayerHitbox.YFromAngleAndDistance(\n  AngleBetweenPositions(PlayerHitbox.CenterX(), PlayerHitbox.CenterY(), Spikes.CenterX(), Spikes.CenterY()) + 180 + RandomInRange(-10, 10),\n  50\n)\n","\"easeOutSine\"","0.2",""]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"FlippableCapability::FlippableBehavior::FlippedX"},"parameters":["PlayerSkin","Flippable"]}],"actions":[{"type":{"value":"Tween::TweenBehavior::AddObjectPositionTween2"},"parameters":["PlayerHitbox","Tween","\"DeathToRightSide\"","PlayerHitbox.XFromAngleAndDistance(\n  AngleBetweenPositions(PlayerHitbox.CenterX(), PlayerHitbox.CenterY(), Spikes.CenterX(), Spikes.CenterY()) - 180 + RandomInRange(-10, 10),\n  50\n)\n","PlayerHitbox.YFromAngleAndDistance(\n  AngleBetweenPositions(PlayerHitbox.CenterX(), PlayerHitbox.CenterY(), Spikes.CenterX(), Spikes.CenterY()) - 180 + RandomInRange(-10, 10),\n  50\n)\n","\"easeOutSine\"","0.2",""]}]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"BooleanObjectVariable"},"parameters":["PlayerHitbox","IsDead","True",""]},{"type":{"inverted":true,"value":"AnimatableCapability::AnimatableBehavior::Name"},"parameters":["PlayerSkin","Animation","=","\"Death\""]}],"actions":[{"type":{"value":"AnimatableCapability::AnimatableBehavior::SetName"},"parameters":["PlayerSkin","Animation","=","\"Death\""]}]}],"parameters":[]},{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"From falling from map","source":"","type":"BuiltinCommonInstructions::Group","events":[{"colorB":228,"colorG":176,"colorR":74,"creationTime":0,"name":"Level 1","source":"","type":"BuiltinCommonInstructions::Group","events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"val