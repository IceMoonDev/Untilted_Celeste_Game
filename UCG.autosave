:"ElapsedTime"},{"propertyName":"Toggle"}]}}],"eventsBasedObjects":[]},{"author":"","category":"General","dimension":"","extensionNamespace":"","fullName":"Snow particles floating effect","gdevelopVersion":"","helpPath":"","iconUrl":"data:image/svg+xml;base64,","name":"SnowMovement","previewIconUrl":"https://asset-resources.gdevelop.io/public-resources/Icons/Line Hero Pack/Master/SVG/Christmas/3050f45ae4abfccb3b5d8c3a96b52235ee54aa69f32626f293995bf932c8aa91_Christmas_snow_flake_winter_cold.svg","shortDescription":"Make particles have floating effect","version":"1.0.0","description":"","tags":["snow","particles","effect"],"authorIds":["IRIhkkTTl2UHhfjrLTTH5GYwkYu1"],"dependencies":[],"globalVariables":[],"sceneVariables":[],"eventsFunctions":[{"description":"Make particles move smoothly to give the snow feel","fullName":"Snow particles","functionType":"Action","name":"SnowMove","sentence":"Make the particles of _PARAM1_ have snow float, at _PARAM2_ time offset, and _PARAM3_ wave speed, and _PARAM4_ floating height, and _PARAM5_ horizontal drift","events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["const emitter        = eventsFunctionContext.getObjects(\"SnowParticle\")[0];","const timeOffset     = eventsFunctionContext.getArgument(\"TimeOffset\");","const wavespeed     = eventsFunctionContext.getArgument(\"WaveSpeed\");","const floatheight     = eventsFunctionContext.getArgument(\"FloatHeight\");","const horizontaldrift     = eventsFunctionContext.getArgument(\"HorizontalDrift\");","","if (!emitter) {","    console.warn(\"SnowParticles not found in scene.\");","    return;","}","","const renderer = emitter._renderer;","if (!renderer || !renderer.emitter || !renderer.emitter._activeParticlesFirst) {","    console.warn(\"Emitter not ready or no active particles found.\");","    return;","}","","let particle = renderer.emitter._activeParticlesFirst;","const time = runtimeScene.getTimeManager().getElapsedTime() / 1000;","","while (particle) {","    // 🎲 If particle doesn't have float data, assign it!","    if (particle._floatOffset === undefined) {","        particle._floatOffset = Math.random() * timeOffset;            // Time offset","        particle._floatSpeed = 0.5 + Math.random() * wavespeed;         // Speed of wave","        particle._floatAmplitude = 10 + Math.random() * floatheight;       // How high it floats","        particle._xDrift = (Math.random() - 0.5) * horizontaldrift;           // Slight horizontal drift","    }","","    // 🎵 Sinusoidal float","    particle.y += Math.sin((time + particle._floatOffset) * particle._floatSpeed) * particle._floatAmplitude * 0.016;","","    // 💨 Optional: Add slow horizontal drift too","    particle.x += particle._xDrift;","","    // 🔁 Next snowflake, please!","    particle = particle.next;","}",""],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":true}],"parameters":[{"description":"Particles object","name":"SnowParticle","supplementaryInformation":"ParticleSystem::ParticleEmitter","type":"objectList"},{"description":"Time offset","name":"TimeOffset","type":"expression"},{"description":"Wave speed","name":"WaveSpeed","type":"expression"},{"description":"How high the snow can float","name":"FloatHeight","type":"expression"},{"description":"Horizontal drift","name":"HorizontalDrift","type":"expression"}],"objectGroups":[]}],"eventsFunctionsFolderStructure":{"folderName":"__ROOT","children":[{"functionName":"SnowMove"}]},"eventsBasedBehaviors":[],"eventsBasedObjects":[]},{"author":"Arthur Pacaud (arthuro555)","category":"General","dimension":"","extensionNamespace":"","fullName":"Array tools","gdevelopVersion":">=5.5.222","helpPath":"","iconUrl":"data:image/svg+xml;base64,","name":"ArrayTools","previewIconUrl":"https://asset-resources.gdevelop.io/public-resources/Icons/Line Hero Pack/Master/SVG/Text Editing/9bfb52500e68d0fd164b1e30bc696e40566187245b80c345848379f40bb6fad7_Text Editing_bullet_points_list.svg","shortDescription":"A collection of utilities and tools for working with arrays.","version":"3.0.0","description":["This extension adds features like:","- Combining arrays (concatenate into new array, append all children to another array)","- Finding a value in an array (find index expression, contains condition)","- Reversing arrays","- Get a portion of an array (slice)","- Add and remove lots of children at specific indices at once (fill, splice, shift, pop, add at index)","- Randomness (shuffle children, get a random child)","- Mathematical operations using arrays (sum of all numbers, biggest/smallest number, average number, median number)","- Sort numbers in an array","- String inter-operation (split string into array, join array array children to string)"],"origin":{"identifier":"ArrayTools","name":"gdevelop-extension-store"},"tags":["array","variable","index","tool","math","string","sort","find","slice","cut","random","copy","combine","concat","append","insert"],"authorIds":["ZgrsWuRTAkXgeuPV9bo0zuEcA2w1"],"changelog":[{"version":"3.0.0","breaking":"- Variables have to be declared"}],"dependencies":[],"globalVariables":[],"sceneVariables":[{"name":"Temp","type":"array","children":[]}],"eventsFunctions":[{"description":"The index of the first variable that equals to a specific number in an array.","fullName":"Index of number","functionType":"ExpressionAndCondition","group":"Scene variables/Array search","name":"IndexOf","sentence":"The first index where _PARAM2_ can be found in _PARAM1_","events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["/** @type {gdjs.Variable} */","const array = eventsFunctionContext.getArgument(\"Array\");","const value = eventsFunctionContext.getArgument(\"Value\");","","eventsFunctionContext.returnValue =","    array.getAllChildrenArray().findIndex(child => child.getAsNumber() === value);",""],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":false}],"expressionType":{"type":"expression"},"parameters":[{"description":"Array to search the value in","name":"A